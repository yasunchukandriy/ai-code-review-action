{
  "name": "ai-code-review-action",
  "version": "1.0.0",
  "description": "GitHub Action that reviews pull requests using Claude AI — catches bugs, security issues, SOLID violations, and performance problems",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "github-action",
    "code-review",
    "claude",
    "ai",
    "anthropic",
    "pull-request"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
